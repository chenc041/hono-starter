{
  "name": "hono-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun run db:dev:prepare",
    "dev": "NODE_ENV=development bun run --hot src/index.ts",
    "prestart": "bun run db:prod:prepare",
    "start": "NODE_ENV=production bun run src/index.ts",
    "check": "bun run lint && bun run typecheck",
    "lint": "biome check .",
    "format": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:studio": "bunx prisma studio",
    "prisma:reset": "bunx prisma migrate reset",
    "seed:admin": "bun run src/scripts/create-admin.ts",
    "db:dev:up": "docker compose up -d db redis",
    "db:dev:prepare": "bun run prisma:generate && bunx prisma migrate deploy",
    "db:dev:status": "bunx prisma migrate status",
    "db:dev:reset": "bun run prisma:reset",
    "db:prod:prepare": "bun run prisma:generate && bunx prisma migrate deploy",
    "db:prod:status": "bunx prisma migrate status"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.5.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "^1.3.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
  }
}
